{
  "env": {
    "browser": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "globals": {
    "chrome": "readonly"
  },
  "ignorePatterns": ["extension/**", "node_modules/**"],
  "extends": ["eslint:recommended"],
  "overrides": [
    {
      "files": ["build.js", "scripts/**/*.js"],
      "env": {
        "node": true,
        "browser": false
      },
      "parserOptions": {
        "sourceType": "commonjs"
      }
    }
  ]
}
