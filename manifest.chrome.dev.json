{
  "manifest_version": 3,
  "name": "SignalizeAI",
  "version": "5.4.0",
  "description": "Sell to any company. Get sales-ready insights and outreach in seconds.",
  "permissions": ["activeTab", "sidePanel", "storage", "tabs", "scripting"],
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://api.signalizeai.org/*",
    "https://dev-api.signalizeai.org/*",
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "extension/background.js"
  },
  "action": {
    "default_title": "SignalizeAI"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://signalizeai.org/*",
        "https://www.signalizeai.org/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["extension/content-auth-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["extension/content-extractor.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "key": ""
}
