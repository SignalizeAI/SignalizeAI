{
  "manifest_version": 3,
  "name": "SignalizeAI",
  "version": "5.4.0",
  "description": "Sell to any company. Get sales-ready insights and outreach in seconds.",
  "permissions": ["activeTab", "storage", "tabs", "scripting"],
  "host_permissions": ["https://*.supabase.co/*", "https://api.signalizeai.org/*", "<all_urls>"],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "signalizeai-extension@signalizeai.org",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "scripts": ["extension/background.js"]
  },
  "action": {
    "default_title": "SignalizeAI"
  },
  "sidebar_action": {
    "default_panel": "sidepanel.html",
    "default_title": "SignalizeAI"
  },
  "content_scripts": [
    {
      "matches": ["https://signalizeai.org/*", "https://www.signalizeai.org/*"],
      "js": ["extension/content-auth-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
